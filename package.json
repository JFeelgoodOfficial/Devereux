{
  "name": "devereux",
  "version": "1.1.0",
  "description": "Devereux — a fast-paced countdown color game",
  "private": true,
  "scripts": {
    "serve":           "serve . -p 3000 --no-clipboard",
    "lint":            "npm run lint:html && npm run lint:css && npm run lint:js",
    "lint:html":       "html-validate index.html",
    "lint:css":        "stylelint \"**/*.css\" --allow-empty-input",
    "lint:js":         "eslint scripts/*.js",
    "test:e2e":        "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:links":      "node scripts/check-links.js",
    "audit:images":    "node scripts/check-images.js",
    "audit:seo":       "node scripts/check-seo-files.js",
    "lighthouse":      "lhci autorun --collect.url=$BASE_URL"
  },
  "devDependencies": {
    "@lhci/cli": "*",
    "@playwright/test": "*",
    "eslint": "*",
    "html-validate": "*",
    "prettier": "*",
    "serve": "*",
    "stylelint": "*",
    "stylelint-config-recess-order": "*",
    "stylelint-config-standard": "*"
  }
}
